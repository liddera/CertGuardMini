<Window x:Class="CertGuard.Desktop.Views.ExpiryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sessão Expirando" Height="200" Width="350"
        WindowStartupLocation="CenterOwner"
        Background="#2d2d44"
        ResizeMode="NoResize"
        Topmost="True">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Sessão expirando em breve"
                   FontSize="16" Foreground="White"
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="1" Text="{Binding Remaining, StringFormat=\\{0\\:mm\\:ss\\}}"
                   FontSize="32" Foreground="#ff6b6b"
                   HorizontalAlignment="Center" FontWeight="Bold"/>

        <TextBlock Grid.Row="2" Text="Deseja estender a sessão?"
                   Foreground="White" HorizontalAlignment="Center"
                   Margin="0,10,0,20"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Estender" Click="Extend_Click"
                    Background="#4ecdc4" Foreground="White"
                    Padding="15,5" Margin="0,0,10,0"/>
            <Button Content="Encerrar" Click="Close_Click"
                    Background="#ff6b6b" Foreground="White"
                    Padding="15,5"/>
        </StackPanel>
    </Grid>
</Window>
