<Window x:Class="CertGuard.Desktop.Views.JustificativaDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Justificativa" Height="250" Width="400"
        WindowStartupLocation="CenterOwner"
        Background="#1a1a2e"
        ResizeMode="NoResize"
        Topmost="True">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Justificativa de Uso"
                   FontSize="18" Foreground="White"
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="1" Text="Informe o motivo do acesso ao certificado:"
                   Foreground="#a0a0a0" Margin="0,0,0,10"/>

        <TextBox Grid.Row="2" x:Name="JustificationBox"
                 AcceptsReturn="True" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 Background="#2d2d44" Foreground="White"
                 BorderBrush="#4a4a6a" Padding="5"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Cancelar" Click="Cancel_Click"
                    Background="#4a4a6a" Foreground="White"
                    Padding="15,5" Margin="0,0,10,0"/>
            <Button Content="Confirmar" Click="Confirm_Click"
                    Background="#4ecdc4" Foreground="White"
                    Padding="15,5"/>
        </StackPanel>
    </Grid>
</Window>
