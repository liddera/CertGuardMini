<Window x:Class="CertGuard.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CertGuard.Desktop.ViewModels"
        xmlns:views="clr-namespace:CertGuard.Desktop.Views"
        Title="CertGuard Desktop" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a2e"
        Closing="Window_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Border Grid.Row="0" Background="#111827" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Border Background="#3b82f6" CornerRadius="6" Padding="6"
                            Margin="0,0,10,0">
                        <TextBlock Text="🛡" FontSize="14" Foreground="White"/>
                    </Border>
                    <TextBlock Text="CertGuard" FontSize="18" Foreground="White"
                               FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="Certificados" Click="ShowCertificates_Click"
                            Margin="0,0,10,0" Padding="12,6"
                            Background="#374151" Foreground="White"
                            BorderColor="#4b5563" BorderThickness="1"/>
                    <Button Content="Sair" Click="Logout_Click"
                            Padding="12,6" Background="#dc2626"
                            Foreground="White" BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Frame Grid.Row="1" x:Name="MainFrame" NavigationUIVisibility="Hidden"
               Background="#1a1a2e"/>

        <!-- Bottom Status Bar -->
        <Border Grid.Row="2" Background="#111827" Padding="10,6">
            <TextBlock Text="CertGuard Desktop v1.0.0" Foreground="#6b7280"
                       FontSize="10"/>
        </Border>
    </Grid>
</Window>
