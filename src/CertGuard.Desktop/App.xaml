<Application x:Class="CertGuard.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/LoginWindow.xaml">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <InverseBoolConverter x:Key="InvertBoolConverter"/>
        <NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <StatusToColorConverter x:Key="StatusToColor"/>
        <StatusToBgColorConverter x:Key="StatusToBgColor"/>
    </Application.Resources>
</Application>
